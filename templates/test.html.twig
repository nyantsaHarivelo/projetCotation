                    <div class="mb-3">
                        <label class="form-label">Prix du litre</label>
                        <input type="number" step="any" class="form-control" id="newPrixLitre" name="prix_litre">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Coût de transport (en Euro)</label>
                        <input type="number" step="any" class="form-control" id="newCoutTransport" name="cout_transport">
