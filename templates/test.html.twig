<!-- Modal de Ajout d'hébergement -->
<div class="modal fade" id="hebergementNewModal" tabindex="-1" aria-labelledby="hebergementModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="hebergementModalLabel">Ajout d'un hébergement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form action="{{ path('hebergement_new') }}" method="POST">
                    <input type="number" step="any" name="id" id="newIdHebergement">
                    <div class="mb-3">
                        <label class="form-label">Nom de l'hébergement</label>
                        <input type="text" class="form-control" id="newNomHebergement" name="nom_hebergement">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Lieu de l'hébergement</label>
                        <input type="text" class="form-control" id="newLieuHebergement" name="lieu_hebergement">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Date de Début</label>
                        <input type="date" class="form-control" id="newDateDebutHebergement" name="date_debut">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Date de Fin</label>
                        <input type="date" class="form-control" id="newDateFinHebergement" name="date_fin">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Coût de l'hébergement (en Euro)</label>
                        <input type="number" step="any" class="form-control" id="newCoutHebergement" name="cout_hebergement">
                    </div>

                    <div class="mb-3">
                        <label for="acheve" class="form-label">Sélection du voyage</label>
                        <select class="form-select" id="voyageHebergement" name="voyage">
                            {% for x in voyages %}
                                <option {% if x.id == voyage.id %}selected{% endif %} 
                                    value="{{x.id}}">
                                    #{{x.id}} | 
                                    {{x.tourist}} -  
                                    [{{x.dateDebut|date_format("EE dd MMMM yyyy")}}]
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Modifier Voyage</button>
                </form>
            </div>
        </div>
    </div>
</div>

