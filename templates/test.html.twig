                    <div class="mb-3">
                        <label for="acheve" class="form-label">Sélection du voyage</label>
                        <select class="form-select" id="voyageHebergement" name="voyage">
                            {% for x in voyages %}
                                <option {% if x.id == voyage.id %}selected{% endif %} 
                                    value="{{x.id}}">
                                    #{{x.id}} | 
                                    {{x.tourist}} -  
                                    [{{x.dateDebut|date_format("EE dd MMMM yyyy")}}]
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">Modifier la Préstation</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

