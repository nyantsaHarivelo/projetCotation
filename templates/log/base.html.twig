<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="{{ asset('/styles/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('/styles/app.css') }}" rel="stylesheet">
    <link href="{{ asset('/styles/font-awesome.all.css') }}" rel="stylesheet">
    <style>
    .auth-bg {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #fde68a, #e0f2fe);
    }

    .auth-card {
        width: 420px;
        background: #fff;
        padding: 32px;
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0,0,0,.12);
    }

    .auth-input {
        border-radius: 12px;
        padding: 10px 14px;
    }

    .password-toggle {
    position: absolute;
    top: 38px;
    right: 14px;
    cursor: pointer;
    color: #9ca3af;
    transition: .2s ease;
}

.password-toggle:hover {
    color: #f59e0b;
}

    </style>
</head>
<body class="auth-bg">
<div class="auth-bg">
    <div class="auth-card auth-card-lg">

        <h3 class="text-center mb-4">Créer un compte</h3>

        {{ form_start(registrationForm) }}

        <!-- Image preview -->
        <div style="display: flex; justify-content: center">
            <img id="imagePreview"
                class="img-fluid mx-auto d-none mb-3"
                style="width: 300px; height: 300px; object-fit: cover; border-radius: 50%">
        </div>

        <!-- Upload -->
        <div id="imageUploadArea" class="btn btn-outline-warning w-100 mb-4">
            <i class="fas fa-camera me-2"></i> Photo de profil
        </div>

        <div class="d-none">
            {{ form_widget(registrationForm.profil) }}
        </div>

        <!-- Username -->
        <div class="mb-3">
            {{ form_label(registrationForm.username) }}
            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control auth-input'}}) }}
            {{ form_errors(registrationForm.username) }}
        </div>

        <!-- Password -->
        <div class="mb-3 position-relative">
            {{ form_label(registrationForm.password.first) }}
            {{ form_widget(registrationForm.password.first, {
                'attr': {
                    'class': 'form-control auth-input pe-5',
                    'id': 'passwordFirst'
                }
            }) }}
            <span class="password-toggle" onclick="togglePassword('passwordFirst', 'eye1')">
                <i id="eye1" class="fas fa-eye"></i>
            </span>
        </div>

        <div class="mb-3 position-relative">
            {{ form_label(registrationForm.password.second) }}
            {{ form_widget(registrationForm.password.second, {
                'attr': {
                    'class': 'form-control auth-input pe-5',
                    'id': 'passwordSecond'
                }
            }) }}
            <span class="password-toggle" onclick="togglePassword('passwordSecond', 'eye2')">
                <i id="eye2" class="fas fa-eye"></i>
            </span>
        </div>


        <hr class="auth-divider">

        <!-- Infos perso -->
        <div class="mb-3">
            <label>Nom</label>
            {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <div class="mb-3">
            <label>Prénoms</label>
            {{ form_widget(registrationForm.prenoms, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <div class="mb-3">
            <label>Profession</label>
            {{ form_widget(registrationForm.profession, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <div class="mb-3">
            <label>Adresse</label>
            {{ form_widget(registrationForm.adresse, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <div class="mb-3">
            <label>Téléphone</label>
            {{ form_widget(registrationForm.numero_tel, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <div class="mb-4">
            <label>Email</label>
            {{ form_widget(registrationForm.mail, {'attr': {'class': 'form-control auth-input'}}) }}
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary w-50" onclick="undoImage()">
                Annuler
            </button>
            <button class="btn btn-primary w-50">
                S’inscrire
            </button>
        </div>

        {{ form_end(registrationForm) }}

        <div class="text-center mt-4">
            <small>Déjà un compte ?</small><br>
            <a href="{{ path('app_login') }}">Se connecter</a>
        </div>

    </div>
</div>

<script>

    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);

        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = "password";
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    const imageArea = document.getElementById('imageUploadArea');
    const imageInput = document.querySelector("input[type = 'file']");
    const imagePreview = document.getElementById('imagePreview');

    function undoImage(){
        imageInput.value = null
        imagePreview.src = ""
        imgElement.classList.add('d-none');
    }
    imageInput.addEventListener('change', (e) => {
        if (e.target.files.length) {
            previewImage(e.target.files[0], imagePreview);
        }
    });

    function previewImage(file, imgElement) {
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                imgElement.src = e.target.result;
                imgElement.classList.remove('d-none');
            }
            reader.readAsDataURL(file);
        }
    }

    imageArea.addEventListener('click', () => imageInput.click());
</script>

</body>
</html>