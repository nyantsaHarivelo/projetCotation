{% extends 'base.html.twig' %}

{% block title %}Dépenses Carburant{% endblock %}

{% block styles %}
   
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <!-- En-tête avec le total -->
   <div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card header-card shadow-lg" style="background: linear-gradient(135deg, #2c3e50, #3498db);">
            <div class="card-body text-center py-4">
                <h1 class="display-6 mb-3">
                    <i class="fas fa-gas-pump me-2"></i>TOTAL LITRES
                </h1>
                <div class="total-amount mb-2">{{ total_litres|default('34.56') }} L</div>
                <p class="lead text-light opacity-75">
                    <i class="fas fa-oil-can me-2"></i>Consommation totale
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
        <div class="card header-card shadow-lg" style="background: linear-gradient(135deg, #27ae60, #2ecc71);">
            <div class="card-body text-center py-4">
                <h1 class="display-6 mb-3">
                    <i class="fas fa-euro-sign me-2"></i>TOTAL EURO
                </h1>
                <div class="total-amount mb-2">€ {{ total_euro|default('32.45') }}</div>
                <p class="lead text-light opacity-75">
                    <i class="fas fa-money-bill-wave me-2"></i>Dépenses totales
                </p>
            </div>
        </div>
    </div>
</div>
    <!-- Tableau des dépenses -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-list-ul me-2 text-primary"></i>Historique des dépenses
                    </h3>
                    <div class="text-muted small mt-1">Dernières transactions de carburant</div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">
                                        <i class="fas fa-calendar me-1"></i> DATE
                                    </th>
                                    <th>
                                        <i class="fas fa-car me-1"></i> VÉHICULE
                                    </th>
                                    <th>
                                        <i class="fas fa-gas- me-1"></i> STATION
                                    </th>
                                    <th class="text-center">
                                        <i class="fas fa-oil-can me-1"></i> LITRES
                                    </th>
                                    <th class="text-center">
                                        <i class="fas fa-tag me-1"></i> PRIX/L
                                    </th>
                                    <th class="text-center">
                                        <i class="fas fa-calculator me-1"></i> TOTAL
                                    </th>
                                    <th class="text-center pe-4">
                                        <i class="fas fa-credit-card me-1"></i> PAIEMENT
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for depense in depenses %}
                                <tr class="align-middle">
                                    <td class="ps-4 fw-medium">
                                        <span class="badge bg-light text-dark p-2">{{ depense.date }}</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-car-side text-secondary me-2"></i>
                                            <div>
                                                <div class="fw-medium">{{ depense.vehicule }}</div>
                                                <small class="text-muted">{{ depense.immatriculation }}</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-medium">{{ depense.station.nom }}</div>
                                        <small class="text-muted">{{ depense.station.localisation }}</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info bg-opacity-10 text-info p-2">
                                            {{ depense.litres }} L
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-primary">
                                        {{ depense.prix_litre }}
                                    </td>
                                    <td class="text-center fw-bold">
                                        <span class="montant-total">{{ depense.total }}</span>
                                    </td>
                                    <td class="text-center pe-4">
                                        {% if depense.paiement == 'Espèces' %}
                                        <span class="badge bg-success bg-opacity-10 text-success p-2">
                                            <i class="fas fa-money-bill-wave me-1"></i> {{ depense.paiement }}
                                        </span>
                                        {% elseif depense.paiement == 'Carte' %}
                                        <span class="badge bg-primary bg-opacity-10 text-primary p-2">
                                            <i class="fas fa-credit-card me-1"></i> {{ depense.paiement }}
                                        </span>
                                        {% else %}
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary p-2">
                                            <i class="fas fa-wallet me-1"></i> {{ depense.paiement }}
                                        </span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="5" class="text-end fw-bold ps-4">Total général :</td>
                                    <td class="text-center fw-bold fs-5 text-success">160 081,60 Ar</td>
                                    <td class="pe-4"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white py-3">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <span class="badge bg-success bg-opacity-10 text-success p-2">
                                        <i class="fas fa-money-bill-wave"></i> Espèces
                                    </span>
                                </div>
                                <small class="text-muted">Toutes les transactions sont payées en espèces</small>
                            </div>
                        </div>
                        <div class="col-md-6 text-end">
                            <button class="btn btn-outline-primary btn-sm me-2">
                                <i class="fas fa-download me-1"></i> Exporter
                            </button>
                            <button class="btn btn-primary btn-sm">
                                <i class="fas fa-plus me-1"></i> Nouvelle dépense
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cartes récapitulatives -->
    <div class="row mt-4">
        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="stat-icon mb-3">
                        <i class="fas fa-car fa-2x text-primary"></i>
                    </div>
                    <h4 class="stat-value">1</h4>
                    <p class="stat-label text-muted mb-0">Véhicule</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="stat-icon mb-3">
                        <i class="fas fa-gas-pump fa-2x text-success"></i>
                    </div>
                    <h4 class="stat-value">4</h4>
                    <p class="stat-label text-muted mb-0">Stations</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="stat-icon mb-3">
                        <i class="fas fa-oil-can fa-2x text-warning"></i>
                    </div>
                    <h4 class="stat-value">34.56 L</h4>
                    <p class="stat-label text-muted mb-0">Total Litres</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="stat-icon mb-3">
                        <i class="fas fa-calendar-alt fa-2x text-info"></i>
                    </div>
                    <h4 class="stat-value">4</h4>
                    <p class="stat-label text-muted mb-0">Transactions</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}

{% endblock %}