<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="{{ asset('/styles/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('/styles/app.css') }}" rel="stylesheet">
    <link href="{{ asset('/styles/font-awesome.all.css') }}" rel="stylesheet">
    <style>
    .auth-bg {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #fde68a, #e0f9fe);
    }

    .auth-card {
        width: 420px;
        background: #fff;
        padding: 32px;
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0,0,0,.12);
    }

    .auth-input {
        border-radius: 12px;
        padding: 10px 14px;
    }

    .password-toggle {
        position: absolute;
        top: 38px;
        right: 14px;
        cursor: pointer;
        color: #9ca3af;
        transition: .2s ease;
    }

    .password-toggle:hover {
        color: #f59e0b;
    }
    </style>
</head>
<body class="auth-bg">

<div class="auth-card">
    <h3 class="text-center mb-4">Connexion</h3>

    {% if error %}
        <div class="alert alert-soft alert-dismissible alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i>
            {{ error.messageKey|trans(error.messageData, 'security') }}
            {# <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button> #}
        </div>
    {% endif %}

    <form method="post">
        <div class="mb-3">
            <label>Nom d'utilisateur</label>
            <input type="text" name="username" value="{{ last_username }}" class="form-control auth-input" required autofocus>
        </div>

        <div class="mb-3 position-relative">
            <label>Mot de passe</label>
            <input type="password" id="passwordInput" name="password"
                class="form-control auth-input pe-5" required>

            <span class="password-toggle" onclick="togglePassword()">
                <i id="eyeIcon" class="fas fa-eye"></i>
            </span>
        </div>


        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="_remember_me">
            <label class="form-check-label">Se souvenir de moi</label>
        </div>

        <button class="btn btn-primary w-100 mb-2">Se connecter</button>
        <a href="{{ path('app_register') }}" class="btn btn-outline-secondary w-100">Créer un compte</a>
    </form>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('passwordInput');
    const icon = document.getElementById('eyeIcon');

    if (input.type === "password") {
        input.type = "text";
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = "password";
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>

</body>
</html>
